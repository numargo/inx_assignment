# INX UAT credentials (one.uat.inx.co → Settings → API). Local only, never commit.
INX_API_KEY_ID=your-api-key-id
# RSA private key PEM as generated by INX. Paste it multiline inside double
# quotes (as below) or on one line with \n-escaped newlines — both work.
INX_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"
# Optional; not used by the app (INX keeps the public key), for reference only.
# INX_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
# ...
# -----END PUBLIC KEY-----"

# Optional overrides (defaults shown)
# PORT=3000
# INX_REST_URL=https://gw-client-api-rest.uat.inx.co
# INX_WS_URL=wss://gw-client-api-ws.uat.inx.co
# INX_MARKET_NAME=BTC-USD
# INX_BOOK_DEPTH=20
